using System;
using System.Collections;
using System.Collections.Generic;
using System.Net.Sockets;
using System.Text;
using System.Threading;
using UnityEngine;
using Logging;

/// <summary>
/// Data structure for LLM analysis results received from Python
/// </summary>
[System.Serializable]
public class LLMResult
{
    public bool success;
    public string response;
    public string camera_id;
    public string timestamp;
    public LLMMetadata metadata;
}

[System.Serializable]
public class LLMMetadata
{
    public string model;
    public float duration_seconds;
    public int image_count;
    public string[] camera_ids;
    public string prompt;
    public string full_prompt;
}

/// <summary>
/// Receives LLM analysis results from Python ResultsServer via TCP.
/// Connects to port 5006 by default and receives JSON results.
/// </summary>
public class LLMResultsReceiver : MonoBehaviour
{
    public static LLMResultsReceiver Instance { get; private set; }

    [Header("Connection Settings")]
    [Tooltip("Host address of Python ResultsServer")]
    [SerializeField]
    private string _serverHost = "127.0.0.1";

    [Tooltip("Port of Python ResultsServer")]
    [SerializeField]
    private int _serverPort = 5006;

    [Tooltip("Auto-connect to ResultsServer on Start")]
    [SerializeField]
    private bool _autoConnect = true;

    [Tooltip("Retry connection if it fails")]
    [SerializeField]
    private bool _retryOnFailure = true;

    [Tooltip("Seconds between connection retry attempts")]
    [SerializeField]
    private float _retryDelay = 5f;

    [Header("Debug")]
    [Tooltip("Log all received results to console")]
    [SerializeField]
    private bool _logResults = true;

    // Events
    public event Action<LLMResult> OnResultReceived;

    // State
    private TcpClient _client;
    private NetworkStream _stream;
    private Thread _receiveThread;
    private bool _isConnected = false;
    private bool _shouldRun = true;
    private Queue<LLMResult> _resultQueue = new Queue<LLMResult>();
    private readonly object _queueLock = new object();

    // Logging
    private MainLogger _logger;

    #region Unity Lifecycle

    /// <summary>
    /// Singleton initialization
    /// </summary>
    private void Awake()
    {
        if (Instance == null)
        {
            Instance = this;
            DontDestroyOnLoad(gameObject);
        }
        else
        {
            Destroy(gameObject);
        }
    }

    /// <summary>
    /// Start connection if auto-connect is enabled
    /// </summary>
    private void Start()
    {
        _logger = MainLogger.Instance;

        if (_autoConnect)
        {
            Connect();
        }
    }

    /// <summary>
    /// Process queued results on main thread
    /// </summary>
    private void Update()
    {
        // Process all queued results
        lock (_queueLock)
        {
            while (_resultQueue.Count > 0)
            {
                LLMResult result = _resultQueue.Dequeue();
                ProcessResult(result);
            }
        }
    }

    /// <summary>
    /// Clean up connection on application quit
    /// </summary>
    private void OnApplicationQuit()
    {
        Disconnect();
    }

    /// <summary>
    /// Clean up connection on destroy
    /// </summary>
    private void OnDestroy()
    {
        if (Instance == this)
        {
            Disconnect();
            Instance = null;
        }
    }

    #endregion

    #region Public API

    /// <summary>
    /// Connect to the Python ResultsServer
    /// </summary>
    public void Connect()
    {
        if (_isConnected)
        {
            LogWarning("Already connected to ResultsServer");
            return;
        }

        StartCoroutine(ConnectCoroutine());
    }

    /// <summary>
    /// Disconnect from the Python ResultsServer
    /// </summary>
    public void Disconnect()
    {
        _shouldRun = false;

        if (_receiveThread != null && _receiveThread.IsAlive)
        {
            _receiveThread.Join(1000); // Wait up to 1 second
        }

        if (_stream != null)
        {
            try
            {
                _stream.Close();
            }
            catch { }
            _stream = null;
        }

        if (_client != null)
        {
            try
            {
                _client.Close();
            }
            catch { }
            _client = null;
        }

        _isConnected = false;
        LogMessage("Disconnected from ResultsServer");
    }

    /// <summary>
    /// Check if connected to ResultsServer
    /// </summary>
    public bool IsConnected() => _isConnected;

    /// <summary>
    /// Get server connection info
    /// </summary>
    public string GetConnectionInfo() => $"{_serverHost}:{_serverPort}";

    #endregion

    #region Connection Management

    /// <summary>
    /// Coroutine to connect to ResultsServer
    /// </summary>
    private IEnumerator ConnectCoroutine()
    {
        while (_shouldRun)
        {
            LogMessage($"Connecting to ResultsServer at {_serverHost}:{_serverPort}...");

            try
            {
                _client = new TcpClient();
                _client.Connect(_serverHost, _serverPort);
                _stream = _client.GetStream();
                _isConnected = true;

                LogMessage("✓ Connected to ResultsServer");

                // Start receive thread
                _receiveThread = new Thread(ReceiveLoop);
                _receiveThread.IsBackground = true;
                _receiveThread.Start();

                yield break; // Success - exit retry loop
            }
            catch (Exception ex)
            {
                LogWarning($"Failed to connect to ResultsServer: {ex.Message}");

                if (!_retryOnFailure)
                {
                    LogWarning("Auto-retry disabled - not retrying connection");
                    yield break;
                }

                LogMessage($"Retrying in {_retryDelay} seconds...");
                yield return new WaitForSeconds(_retryDelay);
            }
        }
    }

    #endregion

    #region Data Reception

    /// <summary>
    /// Background thread loop for receiving data
    /// </summary>
    private void ReceiveLoop()
    {
        byte[] lengthBuffer = new byte[4];

        try
        {
            while (_shouldRun && _isConnected)
            {
                // Read length (4 bytes)
                int bytesRead = ReadExactly(_stream, lengthBuffer, 4);
                if (bytesRead < 4)
                {
                    LogWarning("Connection closed by server");
                    break;
                }

                int dataLength = BitConverter.ToInt32(lengthBuffer, 0);

                if (dataLength <= 0 || dataLength > 10 * 1024 * 1024) // Max 10MB
                {
                    LogError($"Invalid data length received: {dataLength}");
                    break;
                }

                // Read JSON data
                byte[] dataBuffer = new byte[dataLength];
                bytesRead = ReadExactly(_stream, dataBuffer, dataLength);
                if (bytesRead < dataLength)
                {
                    LogWarning("Incomplete data received");
                    break;
                }

                // Parse JSON on background thread
                string json = Encoding.UTF8.GetString(dataBuffer);

                try
                {
                    LLMResult result = JsonUtility.FromJson<LLMResult>(json);

                    // Queue for processing on main thread
                    lock (_queueLock)
                    {
                        _resultQueue.Enqueue(result);
                    }
                }
                catch (Exception parseEx)
                {
                    LogError($"Failed to parse JSON result: {parseEx.Message}\nJSON: {json}");
                }
            }
        }
        catch (Exception ex)
        {
            if (_shouldRun && _isConnected)
            {
                LogError($"Error in receive loop: {ex.Message}");
            }
        }
        finally
        {
            _isConnected = false;

            // Attempt reconnect if enabled
            if (_shouldRun && _retryOnFailure)
            {
                LogMessage("Connection lost - attempting to reconnect...");
                // Trigger reconnect on main thread
                StartCoroutine(ReconnectCoroutine());
            }
        }
    }

    /// <summary>
    /// Read exactly N bytes from stream
    /// </summary>
    private int ReadExactly(NetworkStream stream, byte[] buffer, int count)
    {
        int totalRead = 0;
        while (totalRead < count)
        {
            int read = stream.Read(buffer, totalRead, count - totalRead);
            if (read == 0)
                return totalRead; // Connection closed
            totalRead += read;
        }
        return totalRead;
    }

    /// <summary>
    /// Coroutine to handle reconnection
    /// </summary>
    private IEnumerator ReconnectCoroutine()
    {
        yield return new WaitForSeconds(_retryDelay);

        if (_shouldRun && !_isConnected)
        {
            Connect();
        }
    }

    #endregion

    #region Result Processing

    /// <summary>
    /// Process a received result (called on main thread)
    /// </summary>
    private void ProcessResult(LLMResult result)
    {
        if (result == null)
            return;

        if (_logResults)
        {
            LogMessage($"📥 LLM Result for {result.camera_id}:\n  Response: {result.response}\n  Model: {result.metadata?.model}\n  Duration: {result.metadata?.duration_seconds:F2}s");
        }

        // Fire event for subscribers
        try
        {
            OnResultReceived?.Invoke(result);
        }
        catch (Exception ex)
        {
            LogError($"Error in OnResultReceived event handler: {ex.Message}");
        }
    }

    #endregion

    #region Logging

    /// <summary>
    /// Log a message
    /// </summary>
    private void LogMessage(string message)
    {
        Debug.Log($"[LLMResultsReceiver] {message}");
    }

    /// <summary>
    /// Log a warning
    /// </summary>
    private void LogWarning(string message)
    {
        Debug.LogWarning($"[LLMResultsReceiver] {message}");
    }

    /// <summary>
    /// Log an error
    /// </summary>
    private void LogError(string message)
    {
        Debug.LogError($"[LLMResultsReceiver] {message}");
    }

    #endregion
}
