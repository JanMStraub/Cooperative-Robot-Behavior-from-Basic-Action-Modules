  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp-ACRL::PythonCommunication.SequenceClient
  _autoConnect: 1
  _autoReconnect: 1
  _prompt: "  PARALLEL GROUP 1:\n  - Robot1: Grab blue cube on the left\n\n  PARALLEL
    GROUP 2:\n  - Robot1: Move to coordinate x=0.0, y=0.3, z=0.0\n  - Robot1: Signal
    'object_ready_for_handoff'\n  - Robot2: Wait for signal 'object_ready_for_handoff'\n\n 
    PARALLEL GROUP 3:\n  - Robot2: Move to coordinate x=0.0, y=0.25, z=0.0\n  - Robot2:
    Open gripper\n  - Robot2: Wait 2000 milliseconds\n  - Robot2: Close gripper\n 
    - Robot2: Signal 'handoff_complete'\n\n  PARALLEL GROUP 4:\n  - Robot1: Wait
    for signal 'handoff_complete'\n  - Robot1: Open gripper\n  - Robot1: Move to
    start position at x=-0.3, y=0.15, z=0.0"
  _defaultRobotId: Robot1
  _cameraId: TableStereoCamera
  _logCommands: 1
  _autoExecuteResult: 1
  _lastSequenceStatus: Failed to send
  _commandsCompleted: 0
  _commandsTotal: 0
